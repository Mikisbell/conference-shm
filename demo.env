# demo.env — Safe-to-commit credential template
# ================================================
# This file is tracked by git. It contains:
#   - Documented env vars with their purpose
#   - Demo/free-tier values where safe (public API keys, test accounts)
#   - Placeholder syntax <DESCRIPTION> where real credentials are needed
#
# To activate: cp demo.env .env and fill in private values
# .env is gitignored and NEVER committed.
#
# For new contributors: demo.env shows EXACTLY what keys are needed
# and where to get them — no need to read scattered comments in code.

# ─── Literature search & novelty check ───────────────────────────────────────
# OpenAlex: free public API, this is a free-tier key (no billing risk)
# Used by: tools/check_novelty.py, tools/style_calibration.py
OPENALEX_API_KEY=0tf39ysz34eIKFV3e3caoI

# Semantic Scholar: optional, improves citation analysis throughput
# Register at: https://www.semanticscholar.org/product/api
# Used by: tools/check_novelty.py (--deep), tools/style_calibration.py
SEMANTIC_SCHOLAR_API_KEY=<YOUR_SEMANTIC_SCHOLAR_KEY>

# ─── Academic publishing ─────────────────────────────────────────────────────
# Elsevier / Scopus: for journal metadata and citation counts
# Register at: https://dev.elsevier.com
# Used by: tools/style_calibration.py (venue lookup)
ELSEVIER_API_KEY=<YOUR_ELSEVIER_KEY>

# ─── Seismic data (structural domain) ────────────────────────────────────────
# PEER NGA-West2: free account required to download AT2 ground motion records
# Register at: https://ngawest2.berkeley.edu/users/sign_up
# Used by: tools/peer_downloader.py, tools/fetch_benchmark.py --auto
PEER_EMAIL=<YOUR_PEER_EMAIL>
PEER_PASSWORD=<YOUR_PEER_PASSWORD>

# ─── Environmental domain (optional) ─────────────────────────────────────────
# Google Earth Engine: academic access via https://earthengine.google.com
# Service account JSON — path to file, not the key itself
# Used by: future tools/fetch_environmental_data.py
GEE_SERVICE_ACCOUNT_KEY=<PATH_TO_SERVICE_ACCOUNT_JSON>

# ECMWF CDS: ERA5 reanalysis data — free academic account
# Register at: https://cds.climate.copernicus.eu
# Used by: future tools/fetch_environmental_data.py
CDS_API_KEY=<YOUR_CDS_API_KEY>

# ─── Economics domain (optional) ─────────────────────────────────────────────
# FRED (Federal Reserve Economic Data): free API key
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
# Used by: future tools/fetch_economic_data.py
FRED_API_KEY=<YOUR_FRED_API_KEY>
