# .env.example - Variables de Entorno y Capa de Conectividad
# ==========================================================
# ⚠️ ADVERTENCIA: Copia este archivo a `.env` e inserta tus claves.
# El `.env` nunca debe subirse al control de versiones.

# --- 🧠 LLM ENGINES (Combustible de AITMPL y Teams Lite) ---
OPENAI_API_KEY="your_openai_key_here"
ANTHROPIC_API_KEY="your_anthropic_key_here"        # Required for autoresearch.py
GEMINI_API_KEY="your_gemini_key_here"

# --- 🐙 GITHUB (AutoResearch — proposes + commits improvements automatically) ---
# Get token at: https://github.com/settings/tokens — scope: repo
GITHUB_TOKEN="your_github_token_here"

# --- 📁 PATHS DEL STACK BÉLICO ---
# Engram DB lives at ~/.engram/engram.db (default). Only override if needed:
# ENGRAM_DB_PATH="~/.engram/engram.db"
GENTLEMAN_SKILLS_PATH="./.agent/skills/gentleman"
AITMPL_SKILLS_PATH="./.agent/skills/aitmpl"

# --- 📚 ACADEMIC SEARCH APIs ---
# OpenAlex — REQUIRED for novelty check (check_novelty.py). Public key works out of the box.
# Get your own free key at: https://openalex.org/api-key
OPENALEX_API_KEY=0tf39ysz34eIKFV3e3caoI

# Semantic Scholar (recommended — free key at https://www.semanticscholar.org/product/api)
SEMANTIC_SCHOLAR_API_KEY="your_semantic_scholar_key_here"

# Elsevier/Scopus API (required for Q1/Q2 journal coverage)
# Get free academic key at: https://dev.elsevier.com
ELSEVIER_API_KEY="your_elsevier_key_here"

# --- 🛡️ SECURITY MODES (Guardian Angel Guardrails) ---
GUARDIAN_LEVEL="STRICT"  # Opciones: STRICT, ADVISORY, OFF
ABORT_ON_DIVERGENCE=true
MAX_JITTER_MS=10
FATAL_STRESS_PERCENTAGE=0.85
